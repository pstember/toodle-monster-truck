{
  "all": true,
  "include": [
    "script.js",
    "src/**/*.js"
  ],
  "exclude": [
    "tests/**",
    "node_modules/**",
    "test-results/**",
    "playwright-report/**",
    "*.config.js"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "check-coverage": true,
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80,
  "report-dir": "./coverage",
  "temp-directory": "./coverage/tmp"
}
